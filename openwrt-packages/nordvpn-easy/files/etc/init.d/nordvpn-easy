#!/bin/sh /etc/rc.common

START=95
STOP=10

. /lib/functions.sh

SERVICE_NAME='nordvpn-easy'
UCI_CONFIG='nordvpn_easy'
UCI_SECTION='main'
RUNTIME_CONFIG='/var/etc/nordvpn-easy.conf'
CORE_SCRIPT='/usr/libexec/nordvpn-easy/core.sh'
CONFIG_CONTEXT_LIB='/usr/libexec/nordvpn-easy/lib/config-context.sh'
CRON_PATH='/etc/cron.d/nordvpn-easy'
HOTPLUG_PATH='/etc/hotplug.d/iface/95-nordvpn-easy'
EXTRA_COMMANDS='setup check rotate refresh_countries refresh_countries_force server_catalog public_ip public_country operation_status vpn_status status_json diagnostics_log install_hooks remove_hooks disable_runtime render_runtime_config'
EXTRA_HELP='  setup                 Run setup immediately
  check                 Run one health check immediately
  rotate                Force server rotation immediately
  refresh_countries     Refresh the cached NordVPN country list
  refresh_countries_force Force-refresh the cached NordVPN country list
  server_catalog [country] [force] Print the cached or refreshed NordVPN server catalog JSON
  public_ip             Print the current public IP
  public_country        Print the detected country code for the current public IP
  operation_status      Print whether a NordVPN Easy operation is running
  vpn_status            Print VPN runtime status (active/activating/inactive)
  status_json           Print local VPN runtime status as JSON
  diagnostics_log       Print filtered NordVPN Easy log output
  install_hooks         Install cron and hotplug hooks
  remove_hooks          Remove cron and hotplug hooks
  disable_runtime       Disable the VPN interface and remove hooks
  render_runtime_config Render the temporary shell config'

CONFIG_CONTEXT_LIB_LOADED=0

load_config_context_library() {
	[ "$CONFIG_CONTEXT_LIB_LOADED" -eq 1 ] && return 0
	[ -r "$CONFIG_CONTEXT_LIB" ] || {
		printf '%s\n' "nordvpn-easy: missing config context library $CONFIG_CONTEXT_LIB" >&2
		return 1
	}

	# shellcheck disable=SC1090
	. "$CONFIG_CONTEXT_LIB" || return 1
	CONFIG_CONTEXT_LIB_LOADED=1
}

load_service_config() {
	load_config_context_library || return 1
	nordvpn_easy_load_service_context 'cfg_' "$UCI_CONFIG" "$UCI_SECTION"
}

render_runtime_config() {
	local target_config="${1:-$RUNTIME_CONFIG}"
	local written_options=0

	load_service_config || return 1
	log_service_info "service: rendering runtime config to $target_config ($(nordvpn_easy_service_debug_summary 'cfg_'))"

	written_options="$(nordvpn_easy_render_runtime_config "$target_config" 'cfg_')" || {
		log_service_error "service: failed to render runtime config into $target_config"
		return 1
	}

	log_service_info "service: runtime config rendered at $target_config (written_options=$written_options, $(nordvpn_easy_runtime_file_debug_summary "$target_config"))"
}

run_core_action() {
	local action="$1"
	local action_started_at=''
	local action_finished_at=''
	local action_duration='unknown'
	local action_temp_dir=''
	local action_config=''
	local written_options=0
	local rc=0
	shift

	[ -x "$CORE_SCRIPT" ] || {
		echo "Missing executable core script: $CORE_SCRIPT" >&2
		return 1
	}

	load_service_config || return 1
	nordvpn_easy_mktemp_dir "core-${action}" action_temp_dir || {
		log_service_error "apply: failed to create temporary config workspace for core action '$action'"
		return 1
	}
	action_config="$(nordvpn_easy_temp_file_path "$action_temp_dir" "nordvpn-easy.${action}.conf")"
	written_options="$(nordvpn_easy_render_runtime_config "$action_config" 'cfg_')" || {
		rm -rf -- "$action_temp_dir"
		log_service_error "apply: failed to render temporary config for core action '$action'"
		return 1
	}
	action_started_at="$(date +%s 2>/dev/null || printf '%s' '0')"
	log_service_info "apply: running core action '$action' (args=$(nordvpn_easy_debug_cli_args "$@"))"
	log_service_info "apply: core action context for $action: $(nordvpn_easy_service_debug_summary 'cfg_')"
	log_service_info "apply: rendered temporary config for '$action' at $action_config (written_options=$written_options, $(nordvpn_easy_runtime_file_debug_summary "$action_config"))"
	"$CORE_SCRIPT" "$action" --config "$action_config" "$@"
	rc=$?
	rm -rf -- "$action_temp_dir"
	action_finished_at="$(date +%s 2>/dev/null || printf '%s' '0')"
	case "$action_started_at" in
		''|*[!0-9]*)
			action_duration='unknown'
			;;
		*)
			case "$action_finished_at" in
				''|*[!0-9]*)
					action_duration='unknown'
					;;
				*)
					action_duration=$((action_finished_at - action_started_at))
					;;
			esac
			;;
	esac

	if [ "$rc" -eq 0 ]; then
		log_service_info "apply: core action '$action' completed successfully (duration=${action_duration}s)"
	else
		log_service_error "apply: BLOCKER: core action '$action' failed (duration=${action_duration}s, rc=$rc)"
	fi
	return "$rc"
}

restart_cron_service() {
	/etc/init.d/cron restart >/dev/null 2>&1 ||
	/etc/init.d/cron reload >/dev/null 2>&1 ||
	true
}

log_service_error() {
	local message="$1"

	case "$message" in
		service:*|apply:*|healthcheck:*|poll:*|runtime:*|diagnostics:*)
			;;
		*)
			message="service: $message"
			;;
	esac

	logger -t "$SERVICE_NAME" "$message"
	echo "$SERVICE_NAME: $message" >&2
}

log_service_info() {
	local message="$1"

	case "$message" in
		service:*|apply:*|healthcheck:*|poll:*|runtime:*|diagnostics:*)
			;;
		*)
			message="service: $message"
			;;
	esac

	logger -t "$SERVICE_NAME" "$message"
}

validate_cron_schedule() {
	local schedule="$1"
	local validation_output=''

	if validation_output="$(
		printf '%s' "$schedule" | awk '
		BEGIN {
			valid = 1
			error = ""
			split("59 23 31 12 7", maxv, " ")
			split("0 0 1 1 0", minv, " ")
			split("minute hour day-of-month month day-of-week", field_name, " ")
		}
		function fail(msg) {
			if (valid) {
				valid = 0
				error = msg
			}
		}
		NR > 1 { fail("schedule must be a single line"); exit }
		{
			if (NF != 5) { fail("expected exactly 5 cron fields"); exit }
			for (i = 1; i <= NF; i++) {
				f = $i
				if (f == "*") continue
				if (f ~ /^\*\/[0-9]+$/) {
					step = substr(f, 3) + 0
					if (step < 1 || step > maxv[i] + 0)
						fail(sprintf("field %s has invalid step \"%s\"", field_name[i], f))
					continue
				}
				n = split(f, parts, ",")
				for (j = 1; j <= n; j++) {
					p = parts[j]
					if (p == "") {
						fail(sprintf("field %s contains an empty token", field_name[i]))
						continue
					}
					if (p ~ /^[0-9]+-[0-9]+$/) {
						split(p, rng, "-")
						if (rng[1]+0 < minv[i]+0 || rng[1]+0 > maxv[i]+0)
							fail(sprintf("field %s has out-of-range token \"%s\"", field_name[i], p))
						if (rng[2]+0 < minv[i]+0 || rng[2]+0 > maxv[i]+0)
							fail(sprintf("field %s has out-of-range token \"%s\"", field_name[i], p))
						if (rng[1]+0 > rng[2]+0)
							fail(sprintf("field %s has inverted range \"%s\"", field_name[i], p))
					} else if (p ~ /^[0-9]+$/) {
						if (p+0 < minv[i]+0 || p+0 > maxv[i]+0)
							fail(sprintf("field %s has out-of-range token \"%s\"", field_name[i], p))
					} else {
						fail(sprintf("field %s has invalid token \"%s\"", field_name[i], p))
					}
				}
			}
		}
		END {
			if (!valid)
				printf "%s", error
			exit(valid ? 0 : 1)
		}
	'
	)"; then
		CRON_VALIDATION_ERROR=''
		return 0
	fi

	CRON_VALIDATION_ERROR="$validation_output"
	return 1
}

install_cron_hook() {
	load_service_config
	mkdir -p /etc/cron.d

	if [ "$cfg_enabled" -eq 1 ] && [ -n "$cfg_check_cron_schedule" ]; then
		if ! validate_cron_schedule "$cfg_check_cron_schedule"; then
			rm -f "$CRON_PATH"
			log_service_error "invalid cron schedule '$cfg_check_cron_schedule' (${CRON_VALIDATION_ERROR:-unknown error}); refusing to write $CRON_PATH"
			return 1
		fi

		cat > "$CRON_PATH" <<EOF
$cfg_check_cron_schedule /etc/init.d/$SERVICE_NAME check 2>&1 | logger -t $SERVICE_NAME-cron
EOF
		log_service_info "installed cron hook at $CRON_PATH with schedule '$cfg_check_cron_schedule'"
	else
		rm -f "$CRON_PATH"
		log_service_info "removed cron hook from $CRON_PATH"
	fi

	restart_cron_service
}

install_hotplug_hook() {
	load_service_config
	mkdir -p /etc/hotplug.d/iface

	if [ "$cfg_enabled" -ne 1 ] || [ "$cfg_enable_hotplug" -ne 1 ]; then
		rm -f "$HOTPLUG_PATH"
		log_service_info "removed hotplug hook from $HOTPLUG_PATH"
		return 0
	fi

	cat > "$HOTPLUG_PATH" <<EOF
#!/bin/sh
WAN_IF='$(nordvpn_easy_shell_quote "$cfg_wan_if")'
VPN_IF='$(nordvpn_easy_shell_quote "$cfg_vpn_if")'

case "\$ACTION" in
	ifup|ifupdate|ifdown) ;;
	*) exit 0 ;;
esac

[ "\$INTERFACE" = "\$WAN_IF" ] || [ "\$INTERFACE" = "\$VPN_IF" ] || exit 0

/etc/init.d/$SERVICE_NAME check 2>&1 | logger -t $SERVICE_NAME-hotplug
EOF

	chmod 755 "$HOTPLUG_PATH"
	log_service_info "installed hotplug hook at $HOTPLUG_PATH for wan_if=$cfg_wan_if vpn_if=$cfg_vpn_if"
}

install_hooks() {
	load_service_config || return 1
	log_service_info "install_hooks requested with $(nordvpn_easy_service_debug_summary 'cfg_')"
	log_service_info 'installing runtime hooks'
	install_cron_hook || return 1
	install_hotplug_hook || return 1
	log_service_info 'runtime hooks installed'
}

remove_hooks() {
	log_service_info 'removing runtime hooks'
	rm -f "$CRON_PATH" "$HOTPLUG_PATH"
	restart_cron_service
	log_service_info 'runtime hooks removed'
}

disable_vpn_runtime() {
	load_service_config
	log_service_info "enabled flag is $(nordvpn_easy_enabled_flag_label "${cfg_enabled:-0}"); disabling VPN runtime with $(nordvpn_easy_service_debug_summary 'cfg_')"
	remove_hooks

	if [ "$(uci -q get "network.${cfg_vpn_if}.proto" 2>/dev/null)" != 'wireguard' ]; then
		log_service_info "no WireGuard interface named $cfg_vpn_if is currently configured"
		return 0
	fi

	log_service_info "WireGuard interface $cfg_vpn_if will be marked disabled; the UCI configuration is kept and the interface is not removed"
	uci set "network.${cfg_vpn_if}.disabled"='1'
	uci commit network || {
		log_service_error "failed to commit network while disabling ${cfg_vpn_if}"
		return 1
	}
	log_service_info "marked network.${cfg_vpn_if}.disabled=1"

	ifdown "$cfg_vpn_if" >/dev/null 2>&1 || true
	log_service_info "requested ifdown for $cfg_vpn_if"

	/etc/init.d/network reload >/dev/null 2>&1 ||
	/etc/init.d/network restart >/dev/null 2>&1 || {
		log_service_error "failed to reload network while disabling ${cfg_vpn_if}"
		return 1
	}
	log_service_info "VPN runtime disabled for interface $cfg_vpn_if; it may now appear as not present until re-enabled"
}

start() {
	load_service_config
	log_service_info 'service start requested'

	if [ "$cfg_enabled" -ne 1 ]; then
		disable_vpn_runtime || return 1
		echo "$SERVICE_NAME is disabled in UCI; hooks removed and VPN interface disabled."
		return 0
	fi

	install_hooks || return 1

	if ! run_core_action check; then
		echo "Initial check failed. Hooks are installed; future cron/hotplug runs will retry."
	fi
}

stop() {
	log_service_info 'service stop requested'
	remove_hooks
}

restart() {
	log_service_info 'service restart requested'
	stop
	start
}

reload() {
	log_service_info 'service reload requested'
	restart
}

setup() {
	load_service_config || return 1
	log_service_info "setup requested; enabled flag is $(nordvpn_easy_enabled_flag_label "${cfg_enabled:-0}"); $(nordvpn_easy_service_debug_summary 'cfg_')"
	run_core_action setup
}

check() {
	log_service_info 'manual health-check requested'
	run_core_action check
}

rotate() {
	log_service_info 'manual rotate requested'
	run_core_action rotate
}

refresh_countries() {
	log_service_info 'country cache refresh requested'
	run_core_action refresh_countries
}

refresh_countries_force() {
	log_service_info 'forced country cache refresh requested'
	run_core_action refresh_countries_force
}

server_catalog() {
	local country_query="${1:-}"
	local force_refresh="${2:-0}"

	log_service_info "server catalog requested (country=${country_query:-configured}, force=${force_refresh})"
	run_core_action server_catalog "$country_query" "$force_refresh"
}

public_ip() {
	run_core_action public_ip "$@"
}

public_country() {
	run_core_action public_country "$@"
}

operation_status() {
	run_core_action operation_status
}

vpn_status() {
	run_core_action vpn_status
}

status_json() {
	run_core_action status_json
}

diagnostics_log() {
	log_service_info 'diagnostics log export requested'
	run_core_action diagnostics_log
}

disable_runtime() {
	load_service_config || return 1
	log_service_info "disable_runtime requested; enabled flag is $(nordvpn_easy_enabled_flag_label "${cfg_enabled:-0}"); $(nordvpn_easy_service_debug_summary 'cfg_')"
	disable_vpn_runtime
}
