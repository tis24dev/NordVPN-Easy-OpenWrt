#!/bin/sh /etc/rc.common

START=95
STOP=10

. /lib/functions.sh

SERVICE_NAME='nordvpn-easy'
UCI_CONFIG='nordvpn_easy'
UCI_SECTION='main'
RUNTIME_CONFIG='/var/etc/nordvpn-easy.conf'
CORE_SCRIPT='/usr/libexec/nordvpn-easy/core.sh'
SCHEMA_LIB='/usr/libexec/nordvpn-easy/lib/schema.sh'
RUNTIME_LIB='/usr/libexec/nordvpn-easy/lib/runtime.sh'
SERVICE_CONFIG_LIB='/usr/libexec/nordvpn-easy/lib/service-config.sh'
CRON_PATH='/etc/cron.d/nordvpn-easy'
HOTPLUG_PATH='/etc/hotplug.d/iface/95-nordvpn-easy'
LOCK_DIR='/tmp/nordvpn-easy.lock'
EXTRA_COMMANDS='setup check rotate refresh_countries refresh_countries_force server_catalog public_ip public_country operation_status vpn_status status_json diagnostics_log install_hooks remove_hooks disable_runtime render_runtime_config'
EXTRA_HELP='  setup                 Run setup immediately
  check                 Run one health check immediately
  rotate                Force server rotation immediately
  refresh_countries     Refresh the cached NordVPN country list
  refresh_countries_force Force-refresh the cached NordVPN country list
  server_catalog [country] [force] Print the cached or refreshed NordVPN server catalog JSON
  public_ip             Print the current public IP
  public_country        Print the detected country code for the current public IP
  operation_status      Print whether a NordVPN Easy operation is running
  vpn_status            Print VPN runtime status (active/activating/inactive)
  status_json           Print local VPN runtime status as JSON
  diagnostics_log       Print filtered NordVPN Easy log output
  install_hooks         Install cron and hotplug hooks
  remove_hooks          Remove cron and hotplug hooks
  disable_runtime       Disable the VPN interface and remove hooks
  render_runtime_config Render the temporary shell config'

SCHEMA_LIB_LOADED=0
RUNTIME_LIB_LOADED=0
SERVICE_CONFIG_LIB_LOADED=0

load_schema_library() {
	[ "$SCHEMA_LIB_LOADED" -eq 1 ] && return 0
	[ -r "$SCHEMA_LIB" ] || {
		printf '%s\n' "nordvpn-easy: missing schema library $SCHEMA_LIB" >&2
		return 1
	}

	# shellcheck disable=SC1090
	. "$SCHEMA_LIB" || return 1
	SCHEMA_LIB_LOADED=1
}

load_runtime_library() {
	[ "$RUNTIME_LIB_LOADED" -eq 1 ] && return 0
	[ -r "$RUNTIME_LIB" ] || {
		printf '%s\n' "nordvpn-easy: missing runtime library $RUNTIME_LIB" >&2
		return 1
	}

	# shellcheck disable=SC1090
	. "$RUNTIME_LIB" || return 1
	RUNTIME_LIB_LOADED=1
}

load_service_config_library() {
	[ "$SERVICE_CONFIG_LIB_LOADED" -eq 1 ] && return 0
	[ -r "$SERVICE_CONFIG_LIB" ] || {
		printf '%s\n' "nordvpn-easy: missing service config library $SERVICE_CONFIG_LIB" >&2
		return 1
	}

	load_schema_library || return 1
	# shellcheck disable=SC1090
	. "$SERVICE_CONFIG_LIB" || return 1
	SERVICE_CONFIG_LIB_LOADED=1
}

migrate_service_config() {
	load_service_config_library || return 1
	nordvpn_easy_migrate_service_config "$UCI_CONFIG" "$UCI_SECTION"
}

load_service_config() {
	local option default_value

	load_schema_library || return 1
	migrate_service_config || return 1
	config_load "$UCI_CONFIG"

	for option in $(nordvpn_easy_uci_options); do
		[ "$option" = 'config_schema_version' ] && continue
		default_value="$(nordvpn_easy_default "$option" 2>/dev/null || printf '%s' '')"

		if nordvpn_easy_is_bool_option "$option"; then
			config_get_bool "cfg_${option}" "$UCI_SECTION" "$option" "$default_value"
		else
			config_get "cfg_${option}" "$UCI_SECTION" "$option" "$default_value"
		fi
	done
}

write_runtime_option() {
	local key="$1"
	local value="$2"

	printf "%s='%s'\n" "$key" "$(nordvpn_easy_shell_quote "$value")" >> "$RUNTIME_CONFIG"
}

runtime_file_key_state() {
	local key="$1"
	local raw_value=''

	[ -f "$RUNTIME_CONFIG" ] || {
		printf '%s\n' 'missing-file'
		return 0
	}

	raw_value="$(sed -n "s/^${key}=//p" "$RUNTIME_CONFIG" | head -n 1)"

	if [ -z "$raw_value" ]; then
		printf '%s\n' 'missing'
	elif [ "$raw_value" = "''" ]; then
		printf '%s\n' 'empty'
	else
		printf '%s\n' 'present'
	fi
}

runtime_file_debug_summary() {
	printf '%s' "file_token=$(runtime_file_key_state 'NORDVPN_TOKEN'), "
	printf '%s' "file_wan_if=$(runtime_file_key_state 'WAN_IF'), "
	printf '%s' "file_vpn_if=$(runtime_file_key_state 'VPN_IF'), "
	printf '%s' "file_vpn_addr=$(runtime_file_key_state 'VPN_ADDR'), "
	printf '%s' "file_vpn_port=$(runtime_file_key_state 'VPN_PORT')"
}

render_runtime_config() {
	local option env_name value

	load_service_config || return 1
	umask 077
	mkdir -p /var/etc
	: > "$RUNTIME_CONFIG" || return 1
	log_service_info "rendering runtime config to $RUNTIME_CONFIG ($(runtime_debug_summary))"

	for option in $(nordvpn_easy_runtime_options); do
		env_name="$(nordvpn_easy_env_name "$option")"
		eval "value=\${cfg_${option}}"
		write_runtime_option "$env_name" "$value" || {
			log_service_error "failed to write runtime option $env_name into $RUNTIME_CONFIG"
			return 1
		}
	done

	log_service_info "runtime config rendered at $RUNTIME_CONFIG ($(runtime_file_debug_summary))"
}

run_core_action() {
	local action="$1"
	shift

	[ -x "$CORE_SCRIPT" ] || {
		echo "Missing executable core script: $CORE_SCRIPT" >&2
		return 1
	}

	log_service_info "running core action: $action"
	render_runtime_config || return 1
	log_service_info "core action context for $action: $(runtime_debug_summary)"
	"$CORE_SCRIPT" "$action" "$RUNTIME_CONFIG" "$@"
}

restart_cron_service() {
	/etc/init.d/cron restart >/dev/null 2>&1 ||
	/etc/init.d/cron reload >/dev/null 2>&1 ||
	true
}

log_service_error() {
	local message="$1"

	logger -t "$SERVICE_NAME" "$message"
	echo "$SERVICE_NAME: $message" >&2
}

log_service_info() {
	local message="$1"

	logger -t "$SERVICE_NAME" "$message"
}

enabled_flag_label() {
	if [ "${cfg_enabled:-0}" -eq 1 ]; then
		printf '%s\n' 'checked/on'
	else
		printf '%s\n' 'unchecked/off'
	fi
}

debug_value_or_default() {
	if [ -n "$1" ]; then
		printf '%s\n' "$1"
	else
		printf '%s\n' "$2"
	fi
}

runtime_debug_summary() {
	printf '%s' "enabled=${cfg_enabled:-0} ($(enabled_flag_label)), "
	printf '%s' "mode=$(debug_value_or_default "${cfg_server_selection_mode:-}" 'auto'), "
	printf '%s' "country=$(debug_value_or_default "${cfg_vpn_country:-}" 'automatic'), "
	printf '%s' "preferred_station=$(debug_value_or_default "${cfg_preferred_server_station:-}" 'automatic'), "
	printf '%s' "preferred_hostname=$(debug_value_or_default "${cfg_preferred_server_hostname:-}" 'automatic'), "
	printf '%s' "wan_if=$(debug_value_or_default "${cfg_wan_if:-}" 'unset'), "
	printf '%s' "vpn_if=$(debug_value_or_default "${cfg_vpn_if:-}" 'unset'), "
	printf '%s' "token=$([ -n "${cfg_nordvpn_token:-}" ] && printf '%s' 'present' || printf '%s' 'missing')"
}

json_escape() {
	printf '%s' "$1" | sed ':a;N;$!ba;s/\\/\\\\/g;s/"/\\"/g;s/\n/\\n/g;s/\r/\\r/g'
}

get_operation_status_value() {
	local lock_pid_file="${LOCK_DIR}/pid"
	local lock_action_file="${LOCK_DIR}/action"
	local lock_pid lock_action

	if [ ! -f "$lock_pid_file" ]; then
		printf '%s\n' 'idle'
		return 0
	fi

	lock_pid="$(cat "$lock_pid_file" 2>/dev/null)"

	case "$lock_pid" in
		''|*[!0-9]*)
			printf '%s\n' 'idle'
			return 0
			;;
	esac

	if ! kill -0 "$lock_pid" 2>/dev/null; then
		printf '%s\n' 'idle'
		return 0
	fi

	lock_action="$(cat "$lock_action_file" 2>/dev/null)"

	if [ -n "$lock_action" ]; then
		printf 'busy:%s\n' "$lock_action"
	else
		printf '%s\n' 'busy'
	fi
}

vpn_status_value() {
	load_service_config

	if [ "$cfg_enabled" -ne 1 ]; then
		printf '%s\n' 'inactive'
		return 0
	fi

	if [ "$(uci -q get "network.${cfg_vpn_if}.proto" 2>/dev/null)" != 'wireguard' ]; then
		printf '%s\n' 'inactive'
		return 0
	fi

	if [ "$(uci -q get "network.${cfg_vpn_if}.disabled" 2>/dev/null)" = '1' ]; then
		printf '%s\n' 'inactive'
		return 0
	fi

	if command -v ifstatus >/dev/null 2>&1; then
		if ifstatus "$cfg_vpn_if" 2>/dev/null | jq -er '.up == true' >/dev/null 2>&1; then
			printf '%s\n' 'active'
			return 0
		fi

		printf '%s\n' 'inactive'
		return 0
	fi

	if ip link show dev "$cfg_vpn_if" >/dev/null 2>&1; then
		printf '%s\n' 'active'
		return 0
	fi

	printf '%s\n' 'inactive'
}

peer_section_name() {
	if uci -q get "network.${cfg_vpn_if}server.endpoint_host" >/dev/null 2>&1; then
		printf '%s\n' "${cfg_vpn_if}server"
		return 0
	fi

	uci show network 2>/dev/null | grep "^network\..*=wireguard_${cfg_vpn_if}$" | head -1 | cut -d. -f2 | cut -d= -f1
}

validate_cron_schedule() {
	local schedule="$1"

	printf '%s' "$schedule" | awk '
		BEGIN { valid = 1 }
		NR > 1 { valid = 0 }
		{
			if ($0 !~ /^[0-9*\/,[:space:]-]+$/)
				valid = 0
			if (NF != 5)
				valid = 0
			for (i = 1; i <= NF; i++) {
				if ($i !~ /^[0-9*\/,-]+$/)
					valid = 0
			}
		}
		END { exit(valid ? 0 : 1) }
	'
}

install_cron_hook() {
	load_service_config
	mkdir -p /etc/cron.d

	if [ "$cfg_enabled" -eq 1 ] && [ -n "$cfg_check_cron_schedule" ]; then
		if ! validate_cron_schedule "$cfg_check_cron_schedule"; then
			rm -f "$CRON_PATH"
			log_service_error "invalid cron schedule '$cfg_check_cron_schedule'; refusing to write $CRON_PATH"
			return 1
		fi

		cat > "$CRON_PATH" <<EOF
$cfg_check_cron_schedule /etc/init.d/$SERVICE_NAME check 2>&1 | logger -t $SERVICE_NAME-cron
EOF
		log_service_info "installed cron hook at $CRON_PATH with schedule '$cfg_check_cron_schedule'"
	else
		rm -f "$CRON_PATH"
		log_service_info "removed cron hook from $CRON_PATH"
	fi

	restart_cron_service
}

install_hotplug_hook() {
	load_service_config
	mkdir -p /etc/hotplug.d/iface

	if [ "$cfg_enabled" -ne 1 ] || [ "$cfg_enable_hotplug" -ne 1 ]; then
		rm -f "$HOTPLUG_PATH"
		log_service_info "removed hotplug hook from $HOTPLUG_PATH"
		return 0
	fi

	cat > "$HOTPLUG_PATH" <<EOF
#!/bin/sh
WAN_IF='$(nordvpn_easy_shell_quote "$cfg_wan_if")'
VPN_IF='$(nordvpn_easy_shell_quote "$cfg_vpn_if")'

case "\$ACTION" in
	ifup|ifupdate|ifdown) ;;
	*) exit 0 ;;
esac

[ "\$INTERFACE" = "\$WAN_IF" ] || [ "\$INTERFACE" = "\$VPN_IF" ] || exit 0

/etc/init.d/$SERVICE_NAME check 2>&1 | logger -t $SERVICE_NAME-hotplug
EOF

	chmod 755 "$HOTPLUG_PATH"
	log_service_info "installed hotplug hook at $HOTPLUG_PATH for wan_if=$cfg_wan_if vpn_if=$cfg_vpn_if"
}

install_hooks() {
	load_service_config || return 1
	log_service_info "install_hooks requested with $(runtime_debug_summary)"
	log_service_info 'installing runtime hooks'
	install_cron_hook || return 1
	install_hotplug_hook || return 1
	log_service_info 'runtime hooks installed'
}

remove_hooks() {
	log_service_info 'removing runtime hooks'
	rm -f "$CRON_PATH" "$HOTPLUG_PATH"
	restart_cron_service
	log_service_info 'runtime hooks removed'
}

disable_vpn_runtime() {
	load_service_config
	log_service_info "enabled flag is $(enabled_flag_label); disabling VPN runtime with $(runtime_debug_summary)"
	remove_hooks

	if [ "$(uci -q get "network.${cfg_vpn_if}.proto" 2>/dev/null)" != 'wireguard' ]; then
		log_service_info "no WireGuard interface named $cfg_vpn_if is currently configured"
		return 0
	fi

	log_service_info "WireGuard interface $cfg_vpn_if will be marked disabled; the UCI configuration is kept and the interface is not removed"
	uci set "network.${cfg_vpn_if}.disabled"='1'
	uci commit network || {
		log_service_error "failed to commit network while disabling ${cfg_vpn_if}"
		return 1
	}
	log_service_info "marked network.${cfg_vpn_if}.disabled=1"

	ifdown "$cfg_vpn_if" >/dev/null 2>&1 || true
	log_service_info "requested ifdown for $cfg_vpn_if"

	/etc/init.d/network reload >/dev/null 2>&1 ||
	/etc/init.d/network restart >/dev/null 2>&1 || {
		log_service_error "failed to reload network while disabling ${cfg_vpn_if}"
		return 1
	}
	log_service_info "VPN runtime disabled for interface $cfg_vpn_if; it may now appear as not present until re-enabled"
}

start() {
	load_service_config
	log_service_info 'service start requested'

	if [ "$cfg_enabled" -ne 1 ]; then
		disable_vpn_runtime || return 1
		echo "$SERVICE_NAME is disabled in UCI; hooks removed and VPN interface disabled."
		return 0
	fi

	install_hooks || return 1

	if ! run_core_action check; then
		echo "Initial check failed. Hooks are installed; future cron/hotplug runs will retry."
	fi
}

stop() {
	log_service_info 'service stop requested'
	remove_hooks
}

restart() {
	log_service_info 'service restart requested'
	stop
	start
}

reload() {
	log_service_info 'service reload requested'
	restart
}

setup() {
	load_service_config || return 1
	log_service_info "setup requested; enabled flag is $(enabled_flag_label); $(runtime_debug_summary)"
	run_core_action setup
}

check() {
	log_service_info 'manual health-check requested'
	run_core_action check
}

rotate() {
	log_service_info 'manual rotate requested'
	run_core_action rotate
}

refresh_countries() {
	log_service_info 'country cache refresh requested'
	run_core_action refresh_countries
}

refresh_countries_force() {
	log_service_info 'forced country cache refresh requested'
	run_core_action refresh_countries_force
}

server_catalog() {
	local country_query="${1:-}"
	local force_refresh="${2:-0}"

	log_service_info "server catalog requested (country=${country_query:-configured}, force=${force_refresh})"
	run_core_action server_catalog "$country_query" "$force_refresh"
}

public_ip() {
	run_core_action public_ip
}

public_country() {
	run_core_action public_country
}

operation_status() {
	get_operation_status_value
}

vpn_status() {
	vpn_status_value
}

status_json() {
	local peer_section
	local wg_dump
	local vpn_state
	local operation
	local endpoint='N/A'
	local latest_handshake='Never'
	local latest_handshake_epoch='0'
	local transfer_rx='0 B'
	local transfer_rx_bytes='0'
	local transfer_tx='0 B'
	local transfer_tx_bytes='0'
	local connected='false'
	local current_hostname=''
	local current_station=''
	local current_city=''
	local current_country=''
	local current_load=''
	local preferred_hostname=''
	local preferred_station=''

	load_service_config
	load_runtime_library || return 1
	peer_section="$(peer_section_name)"
	vpn_state="$(vpn_status_value)"
	operation="$(get_operation_status_value)"

	if [ -n "$peer_section" ]; then
		current_hostname="$(uci -q get "network.${peer_section}.nordvpn_hostname" 2>/dev/null)"
		current_station="$(uci -q get "network.${peer_section}.nordvpn_station" 2>/dev/null)"
		current_city="$(uci -q get "network.${peer_section}.nordvpn_city" 2>/dev/null)"
		current_country="$(uci -q get "network.${peer_section}.nordvpn_country_code" 2>/dev/null)"
		current_load="$(uci -q get "network.${peer_section}.nordvpn_load" 2>/dev/null)"

		[ -n "$current_hostname" ] || current_hostname="$(uci -q get "network.${peer_section}.description" 2>/dev/null)"
		[ -n "$current_station" ] || current_station="$(uci -q get "network.${peer_section}.endpoint_host" 2>/dev/null)"
	fi

	preferred_hostname="$cfg_preferred_server_hostname"
	preferred_station="$cfg_preferred_server_station"

	wg_dump="$(wg show "$cfg_vpn_if" dump 2>/dev/null)"

	if [ -n "$wg_dump" ]; then
		IFS="$(printf '\t')" read -r endpoint latest_handshake_epoch transfer_rx_bytes transfer_tx_bytes <<EOF
$(nordvpn_easy_parse_wg_dump_peer "$wg_dump")
EOF

		latest_handshake="$(nordvpn_easy_humanize_handshake_age "$latest_handshake_epoch")"
		transfer_rx="$(nordvpn_easy_format_human_bytes "$transfer_rx_bytes")"
		transfer_tx="$(nordvpn_easy_format_human_bytes "$transfer_tx_bytes")"

		if nordvpn_easy_handshake_epoch_indicates_connection "$latest_handshake_epoch"; then
			connected='true'
		fi
	fi

	cat <<EOF
{
  "enabled": $([ "$cfg_enabled" -eq 1 ] && printf '%s' 'true' || printf '%s' 'false'),
  "server_selection_mode": "$(json_escape "$cfg_server_selection_mode")",
  "selected_country": "$(json_escape "$cfg_vpn_country")",
  "interface": "$(json_escape "$cfg_vpn_if")",
  "vpn_status": "$(json_escape "$vpn_state")",
  "operation_status": "$(json_escape "$operation")",
  "connected": $connected,
  "endpoint": "$(json_escape "$endpoint")",
  "latest_handshake": "$(json_escape "$latest_handshake")",
  "latest_handshake_epoch": $latest_handshake_epoch,
  "transfer_rx": "$(json_escape "$transfer_rx")",
  "transfer_rx_bytes": $transfer_rx_bytes,
  "transfer_tx": "$(json_escape "$transfer_tx")",
  "transfer_tx_bytes": $transfer_tx_bytes,
  "current_server_hostname": "$(json_escape "$current_hostname")",
  "current_server_station": "$(json_escape "$current_station")",
  "current_server_city": "$(json_escape "$current_city")",
  "current_server_country": "$(json_escape "$current_country")",
  "current_server_load": "$(json_escape "$current_load")",
  "preferred_server_hostname": "$(json_escape "$preferred_hostname")",
  "preferred_server_station": "$(json_escape "$preferred_station")"
}
EOF
}

diagnostics_log() {
	local tmp_log

	log_service_info 'diagnostics log export requested'
	command -v logread >/dev/null 2>&1 || {
		log_service_error "logread command not found"
		return 1
	}

	tmp_log="/tmp/${SERVICE_NAME}.diagnostics.$$"

	logread -e "$SERVICE_NAME" > "$tmp_log" || {
		rm -f "$tmp_log"
		return 1
	}

	tail -n 500 "$tmp_log"
	rm -f "$tmp_log"
}

disable_runtime() {
	load_service_config || return 1
	log_service_info "disable_runtime requested; enabled flag is $(enabled_flag_label); $(runtime_debug_summary)"
	disable_vpn_runtime
}
